<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Howard Armory — Certification Panel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=IBM+Plex+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
  <script src="/HA-EE/src/javascript/systeme.js" type="module"></script>
<style>
/* ══ RESET & ROOT ══ */
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --gold:#C9A84C;--gold2:#E8C96A;--gold-dim:rgba(201,168,76,0.12);--gold-border:rgba(201,168,76,0.25);
  --red:#8B1A1A;--red2:#B22222;
  --bg:#06080A;--bg2:#0D1117;--bg3:#131920;--bg4:#1a2230;
  --border:rgba(255,255,255,0.06);--border2:rgba(255,255,255,0.1);
  --text:#D8D0C0;--text-dim:#7A7060;--text-muted:#3A3530;
  --green:#2E7D4F;--green2:#3A9E63;
  --blue:#1E3A5F;
  --mono:'IBM Plex Mono',monospace;
  --serif:'Crimson Pro',serif;
  --display:'Cinzel',serif;
}
body{font-family:var(--mono);background:var(--bg);color:var(--text);min-height:100vh;font-size:13px;line-height:1.6;}
::-webkit-scrollbar{width:5px;} ::-webkit-scrollbar-track{background:transparent;} ::-webkit-scrollbar-thumb{background:rgba(201,168,76,0.2);border-radius:3px;}

/* ══ TOPBAR ══ */
.topbar{
  background:linear-gradient(180deg,#0D1117 0%,#0a0e14 100%);
  border-bottom:1px solid var(--gold-border);
  padding:0 2rem; height:56px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;
}
.topbar-left{display:flex;align-items:center;gap:16px;}
.topbar-logo{font-family:var(--display);font-size:18px;letter-spacing:0.2em;color:var(--gold);line-height:1;}
.topbar-logo span{color:rgba(216,208,192,0.5);font-size:11px;display:block;letter-spacing:0.4em;margin-top:1px;}
.topbar-sep{width:1px;height:28px;background:var(--border2);}
.topbar-session{font-size:11px;color:var(--text-dim);letter-spacing:0.1em;}
.topbar-session strong{color:var(--gold);font-weight:500;}
.topbar-right{display:flex;align-items:center;gap:12px;}
.topbar-badge{font-size:9px;letter-spacing:0.25em;color:var(--text-dim);border:1px solid var(--border);padding:4px 12px;border-radius:2px;text-transform:uppercase;}

/* ══ TABS ══ */
.tabs-nav{background:var(--bg2);border-bottom:1px solid var(--border);padding:0 2rem;display:flex;gap:0;overflow-x:auto;}
.tab-btn{
  background:none;border:none;border-bottom:2px solid transparent;
  color:var(--text-dim);font-family:var(--mono);font-size:10px;letter-spacing:0.2em;
  text-transform:uppercase;padding:14px 22px;cursor:pointer;transition:all 0.2s;white-space:nowrap;
}
.tab-btn:hover{color:var(--text);}
.tab-btn.active{color:var(--gold);border-bottom-color:var(--gold);}
.tab-btn i{margin-right:7px;}

/* ══ LAYOUT ══ */
.main{padding:2rem;max-width:1100px;margin:0 auto;}
.tab-panel{display:none;animation:fadeIn 0.2s ease;}
.tab-panel.active{display:block;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}

/* ══ SECTION HEADER ══ */
.section-header{margin-bottom:2rem;padding-bottom:1rem;border-bottom:1px solid var(--gold-border);}
.section-title{font-family:var(--display);font-size:22px;letter-spacing:0.15em;color:var(--gold);line-height:1.2;}
.section-sub{font-size:10px;letter-spacing:0.25em;color:var(--text-dim);text-transform:uppercase;margin-top:6px;}

/* ══ CARDS ══ */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:1.5rem;margin-bottom:1.25rem;}
.card-title{font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold);margin-bottom:1.2rem;padding-bottom:0.6rem;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.card-title i{font-size:11px;}

/* ══ INSTRUCTEUR BANNER ══ */
.inst-banner{
  background:linear-gradient(135deg,var(--bg3),var(--bg4));
  border:1px solid var(--gold-border);
  border-radius:3px;padding:1.25rem 1.5rem;
  display:flex;align-items:center;gap:1.5rem;
  margin-bottom:1.25rem;
}
.inst-avatar{
  width:52px;height:52px;border-radius:3px;
  background:var(--gold-dim);border:1px solid var(--gold-border);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--display);font-size:18px;color:var(--gold);flex-shrink:0;
}
.inst-info{flex:1;}
.inst-name{font-family:var(--display);font-size:16px;color:var(--text);letter-spacing:0.1em;}
.inst-name span{color:var(--gold);}
.inst-meta{font-size:10px;color:var(--text-dim);letter-spacing:0.15em;text-transform:uppercase;margin-top:3px;}
.inst-status{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--green2);letter-spacing:0.1em;text-transform:uppercase;margin-top:6px;}
.inst-status::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green2);flex-shrink:0;}
.inst-mode-toggle input[type=radio]{accent-color:var(--gold);}

/* ══ FORMATION SELECT ══ */
.formation-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;margin-bottom:1rem;}
.formation-card{
  background:var(--bg3);border:1px solid var(--border);border-radius:3px;
  padding:1rem;cursor:pointer;transition:all 0.2s;position:relative;
}
.formation-card:hover{border-color:var(--gold-border);}
.formation-card.selected{border-color:var(--gold);background:var(--gold-dim);}
.formation-card.selected::after{content:'✓';position:absolute;top:8px;right:10px;color:var(--gold);font-size:12px;}
.formation-card.soon{opacity:0.4;cursor:not-allowed;}
.fc-price{font-family:var(--display);font-size:18px;color:var(--gold);margin-bottom:4px;}
.fc-name{font-size:11px;color:var(--text);font-weight:500;letter-spacing:0.05em;margin-bottom:2px;}
.fc-desc{font-size:10px;color:var(--text-dim);letter-spacing:0.05em;}
.fc-soon{font-size:9px;letter-spacing:0.2em;color:var(--text-dim);text-transform:uppercase;margin-top:4px;}
.fc-popular{position:absolute;top:-1px;right:-1px;background:var(--gold);color:#0a0800;font-size:8px;letter-spacing:0.15em;text-transform:uppercase;padding:3px 8px;border-radius:0 3px 0 3px;font-weight:700;}

/* ══ FORM ELEMENTS ══ */
.f-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;}
.f-row.full{grid-template-columns:1fr;}
.f-row.tri{grid-template-columns:1fr 1fr 1fr;}
label{display:block;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-bottom:6px;}
input[type=text],input[type=date],select,textarea{
  width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:2px;
  color:var(--text);font-family:var(--mono);font-size:12px;padding:9px 12px;outline:none;transition:border-color 0.2s;
}
input:focus,select:focus,textarea:focus{border-color:var(--gold);}
select option{background:#131920;}
textarea{resize:vertical;min-height:80px;font-size:12px;}
input[type=date]::-webkit-calendar-picker-indicator{filter:invert(0.4);}

/* ══ DECLARATION PREVIEW ══ */
.decl-box{
  background:var(--bg3);border:1px solid var(--gold-border);border-radius:3px;
  padding:1.75rem;font-family:var(--serif);font-size:15px;line-height:2.1;color:var(--text);
  margin-bottom:1.25rem;
}
.decl-box .fill{
  color:var(--gold);font-family:var(--mono);font-size:11px;
  border-bottom:1px dashed rgba(201,168,76,0.5);padding:1px 5px;letter-spacing:0.05em;
}
.decl-box .blank{color:var(--text-muted);font-family:var(--mono);font-size:11px;border-bottom:1px dashed var(--text-muted);padding:1px 8px;}

/* ══ COURS BUILDER ══ */
.cours-header{font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-dim);
  margin-bottom:0.75rem;display:flex;align-items:center;gap:10px;}
.cours-header::after{content:'';flex:1;height:1px;background:var(--border);}
.cours-list{display:flex;flex-direction:column;gap:6px;margin-bottom:8px;}
.cours-item{
  display:grid;grid-template-columns:1fr 90px 90px 30px;gap:8px;align-items:center;
  background:var(--bg3);border:1px solid var(--border);border-radius:2px;padding:8px 12px;
}
.cours-item input[type=text]{background:transparent;border:none;padding:0;font-size:12px;}
.cours-item input[type=text]:focus{border:none;outline:none;}
.chk-label{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--text-dim);cursor:pointer;white-space:nowrap;user-select:none;}
.chk-label input[type=checkbox]{width:13px;height:13px;accent-color:var(--gold);cursor:pointer;flex-shrink:0;}
.chk-label.acq input:checked+span{color:var(--green2);}
.chk-label.vu input:checked+span{color:var(--text);}
.btn-del{background:none;border:1px solid rgba(139,26,26,0.3);color:var(--red2);
  width:26px;height:26px;border-radius:2px;cursor:pointer;font-size:10px;
  display:flex;align-items:center;justify-content:center;transition:all 0.2s;}
.btn-del:hover{background:rgba(139,26,26,0.15);}
.btn-add{background:none;border:1px dashed var(--border);color:var(--text-dim);
  font-family:var(--mono);font-size:10px;letter-spacing:0.15em;text-transform:uppercase;
  padding:7px 16px;border-radius:2px;cursor:pointer;width:100%;margin-top:4px;transition:all 0.2s;}
.btn-add:hover{border-color:var(--gold);color:var(--gold);}

/* ══ BUTTONS ══ */
.btn-primary{
  background:linear-gradient(135deg,#9A7B2A,var(--gold));color:#050300;
  border:none;font-family:var(--display);font-size:14px;letter-spacing:0.2em;
  padding:12px 36px;border-radius:2px;cursor:pointer;transition:opacity 0.2s;
}
.btn-primary:hover{opacity:0.9;}
.btn-secondary{background:none;border:1px solid var(--border);color:var(--text-dim);
  font-family:var(--mono);font-size:10px;letter-spacing:0.1em;padding:8px 20px;
  border-radius:2px;cursor:pointer;transition:all 0.2s;}
.btn-secondary:hover{border-color:var(--text-dim);color:var(--text);}
.btn-row{display:flex;gap:12px;align-items:center;margin-top:1.5rem;flex-wrap:wrap;}

/* ══ TABLE REGISTRE ══ */
.certif-table{width:100%;border-collapse:collapse;}
.certif-table th{text-align:left;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;
  color:var(--text-dim);padding:8px 14px;border-bottom:1px solid var(--gold-border);font-weight:400;}
.certif-table td{padding:12px 14px;border-bottom:1px solid var(--border);vertical-align:middle;}
.certif-table tr:hover td{background:var(--bg3);}
.t-name{font-family:var(--serif);font-size:15px;color:var(--text);}
.t-ref{font-size:10px;color:var(--text-dim);letter-spacing:0.1em;}
.t-date{font-size:11px;color:var(--text-dim);}
.type-pill{display:inline-block;font-size:8px;letter-spacing:0.15em;text-transform:uppercase;
  padding:2px 8px;border-radius:2px;border:1px solid var(--border);}
.type-pill.pratique{border-color:rgba(201,168,76,0.4);color:var(--gold);}
.type-pill.theorique{border-color:rgba(46,125,79,0.4);color:var(--green2);}
.type-pill.mixte{border-color:rgba(30,58,95,0.6);color:#5A9FD4;}
.btn-view{background:none;border:1px solid var(--border);color:var(--text-dim);
  font-family:var(--mono);font-size:9px;letter-spacing:0.1em;padding:4px 12px;
  border-radius:2px;cursor:pointer;transition:all 0.2s;}
.btn-view:hover{border-color:var(--gold);color:var(--gold);}

/* ══ SEARCH ══ */
.search-row{display:flex;gap:10px;margin-bottom:1.5rem;}
.search-row input{flex:1;background:var(--bg2);border:1px solid var(--border);color:var(--text);
  font-family:var(--mono);font-size:12px;padding:10px 14px;border-radius:2px;outline:none;}
.search-row input:focus{border-color:var(--gold);}
.search-row button{background:var(--gold);color:#050300;border:none;font-family:var(--display);
  font-size:13px;letter-spacing:0.15em;padding:10px 28px;border-radius:2px;cursor:pointer;}

/* ══ STATS GRID ══ */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:1.5rem;}
.stat-card{background:var(--bg2);border:1px solid var(--border);border-radius:3px;padding:1rem;text-align:center;}
.stat-num{font-family:var(--display);font-size:30px;color:var(--gold);letter-spacing:0.05em;}
.stat-lbl{font-size:8px;letter-spacing:0.25em;text-transform:uppercase;color:var(--text-dim);margin-top:3px;}

/* ══ MODAL ══ */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.9);z-index:200;
  display:none;align-items:flex-start;justify-content:center;padding:2rem;overflow-y:auto;
}
.modal-overlay.open{display:flex;}
.modal-box{
  background:var(--bg2);border:1px solid var(--gold-border);border-radius:3px;
  width:100%;max-width:860px;padding:1.5rem;margin:auto;
}
.modal-actions{display:flex;gap:10px;margin-bottom:1.5rem;flex-wrap:wrap;}
.modal-close{background:none;border:1px solid var(--border);color:var(--text-dim);
  font-family:var(--mono);font-size:9px;letter-spacing:0.15em;padding:6px 16px;
  border-radius:2px;cursor:pointer;margin-left:auto;}
.modal-close:hover{border-color:var(--red2);color:var(--red2);}

/* ══ NOTIF ══ */
.notif{position:fixed;bottom:2rem;right:2rem;background:var(--bg3);border:1px solid var(--gold-border);
  padding:1rem 1.5rem;border-radius:3px;font-size:12px;color:var(--gold);z-index:300;
  display:none;animation:slideUp 0.3s ease;}
@keyframes slideUp{from{transform:translateY(8px);opacity:0;}to{transform:translateY(0);opacity:1;}}

/* ════════════════════════════════════════════
   CERTIFICAT — STYLE DOCUMENT NATIONAL USA
   ════════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&display=swap');

.certif-wrap{
  background:#FDFAF3;
  color:#1A1208;
  position:relative;
  font-family:'Crimson Pro',serif;
  overflow:hidden;
}

/* Bordure ornementale externe */
.certif-outer-border{
  position:absolute;inset:12px;
  border:2px solid #8B6914;
  pointer-events:none;z-index:1;
}
.certif-inner-border{
  position:absolute;inset:17px;
  border:1px solid rgba(139,105,20,0.4);
  pointer-events:none;z-index:1;
}

/* Coins ornementaux */
.certif-corner{position:absolute;width:50px;height:50px;z-index:2;}
.certif-corner svg{width:100%;height:100%;}
.certif-corner.tl{top:8px;left:8px;}
.certif-corner.tr{top:8px;right:8px;transform:scaleX(-1);}
.certif-corner.bl{bottom:8px;left:8px;transform:scaleY(-1);}
.certif-corner.br{bottom:8px;right:8px;transform:scale(-1,-1);}

/* Watermark */
.certif-watermark{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%) rotate(-30deg);
  font-family:'Cinzel',serif;font-size:90px;font-weight:900;
  letter-spacing:0.05em;color:rgba(139,105,20,0.04);
  white-space:nowrap;pointer-events:none;z-index:0;
  text-align:center;line-height:1.1;
}

/* Contenu */
.certif-content{position:relative;z-index:2;padding:52px 60px 40px;}

/* Header */
.certif-header{text-align:center;margin-bottom:28px;}
.certif-seal-row{display:flex;align-items:center;justify-content:center;gap:24px;margin-bottom:16px;}
.certif-seal{
  width:80px;height:80px;border-radius:50%;
  border:3px solid #8B6914;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:rgba(139,105,20,0.06);
  font-family:'Cinzel',serif;color:#6B5010;text-align:center;
  font-size:8px;letter-spacing:0.12em;line-height:1.4;flex-shrink:0;
}
.certif-seal-inner{font-size:14px;font-weight:700;display:block;letter-spacing:0.1em;}
.certif-corp{font-family:'Cinzel',serif;font-size:32px;font-weight:700;letter-spacing:0.2em;color:#4A2D00;}
.certif-corp-sub{font-size:11px;letter-spacing:0.35em;color:#8B6914;text-transform:uppercase;font-family:'IBM Plex Mono',monospace;margin-top:4px;}
.certif-divider{
  display:flex;align-items:center;gap:12px;margin:14px 0;
}
.certif-divider-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);}
.certif-divider-diamond{width:8px;height:8px;background:#8B6914;transform:rotate(45deg);flex-shrink:0;}
.certif-doc-title{font-family:'Cinzel',serif;font-size:20px;letter-spacing:0.3em;color:#2A1800;text-transform:uppercase;margin:8px 0 4px;}
.certif-doc-sub{font-size:12px;letter-spacing:0.2em;color:#8B6914;font-family:'IBM Plex Mono',monospace;text-transform:uppercase;}
.certif-ref{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#A08040;margin-top:6px;letter-spacing:0.1em;}

/* Corps */
.certif-body{
  font-size:15px;line-height:2;color:#1A1208;margin:20px 0;
  text-align:justify;
}
.certif-body .hl{
  font-weight:600;border-bottom:1px solid rgba(139,105,20,0.5);padding-bottom:1px;
}
.certif-body .inst-hl{color:#4A2D00;font-weight:600;}
.certif-body .client-hl{color:#1A4A2A;font-weight:600;}
.certif-body .form-hl{font-style:italic;font-weight:600;color:#2A1800;}

/* Formation encart */
.certif-formation-box{
  border:1px solid rgba(139,105,20,0.3);border-left:4px solid #8B6914;
  background:rgba(200,184,112,0.07);padding:12px 20px;margin:16px 0;
  border-radius:0 2px 2px 0;
}
.certif-formation-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:#8B6914;margin-bottom:4px;}
.certif-formation-name{font-size:17px;font-weight:600;color:#2A1800;font-style:italic;}
.certif-formation-meta{font-family:'IBM Plex Mono',monospace;font-size:10px;color:#A08040;margin-top:4px;}

/* Cours blocks */
.certif-cours-section{margin:18px 0;}
.certif-cours-label{
  font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.3em;
  text-transform:uppercase;color:#8B6914;margin-bottom:10px;
  display:flex;align-items:center;gap:10px;
}
.certif-cours-label::after{content:'';flex:1;height:1px;background:rgba(139,105,20,0.2);}
.certif-cours-list{list-style:none;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:4px 20px;}
.certif-cours-list li{
  display:flex;align-items:center;gap:10px;
  font-size:13px;padding:5px 0;
  border-bottom:1px dotted rgba(139,105,20,0.15);
}
.certif-cours-list li .cc-status{
  font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:0.1em;
  padding:1px 7px;border-radius:1px;border:1px solid;flex-shrink:0;text-transform:uppercase;
}
.certif-cours-list li.acq .cc-status{border-color:#1A5C2E;color:#1A5C2E;background:rgba(26,92,46,0.08);}
.certif-cours-list li.vu .cc-status{border-color:#8B6914;color:#8B6914;background:rgba(139,105,20,0.06);}
.certif-cours-list li.acq .cc-name{color:#1A3A22;}
.certif-cours-list li.vu .cc-name{color:#5A4820;}

/* Observations */
.certif-obs{
  margin:18px 0;padding:14px 20px;
  background:rgba(200,184,112,0.05);border:1px dashed rgba(139,105,20,0.25);
  border-radius:2px;
}
.certif-obs-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.2em;text-transform:uppercase;color:#8B6914;margin-bottom:6px;}
.certif-obs-text{font-size:14px;color:#3A2A10;font-style:italic;line-height:1.8;}

/* Séparateur central */
.certif-mid-divider{
  text-align:center;margin:20px 0;color:#8B6914;font-size:16px;letter-spacing:0.5em;
}

/* Signatures */
.certif-sigs{
  display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;
  margin-top:30px;padding-top:20px;border-top:1px solid rgba(139,105,20,0.3);
}
.sig-block{text-align:center;}
.sig-line{border-top:1px solid #8B6914;margin:28px auto 8px;width:85%;}
.sig-name{font-family:'Cinzel',serif;font-size:12px;font-weight:600;color:#2A1800;letter-spacing:0.05em;}
.sig-role{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.12em;text-transform:uppercase;color:#8B6914;margin-top:3px;}
.sig-date{font-family:'IBM Plex Mono',monospace;font-size:9px;color:#A08040;margin-top:2px;}

/* Footer légal */
.certif-legal{
  margin-top:24px;padding-top:16px;border-top:1px solid rgba(139,105,20,0.2);
  display:flex;justify-content:space-between;align-items:flex-end;gap:20px;
}
.certif-legal-left{font-size:11px;color:#8B7040;line-height:1.7;font-style:italic;max-width:360px;}
.certif-legal-left strong{font-style:normal;font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.1em;color:#6B5010;display:block;margin-bottom:3px;}
.certif-legal-right{text-align:right;flex-shrink:0;}
.certif-legal-right .qr-placeholder{
  width:56px;height:56px;border:1px solid rgba(139,105,20,0.3);
  display:flex;align-items:center;justify-content:center;
  font-size:7px;color:#A08040;letter-spacing:0.1em;text-align:center;
  font-family:'IBM Plex Mono',monospace;margin:0 0 4px auto;
  background:rgba(200,184,112,0.05);
}
.certif-legal-right .cert-url{font-family:'IBM Plex Mono',monospace;font-size:8px;color:#A08040;letter-spacing:0.05em;}

@media print{
  body{background:#fff;}
  .topbar,.tabs-nav,.modal-actions,.notif{display:none!important;}
  .modal-overlay{position:static;padding:0;background:none;display:block!important;}
  .modal-box{border:none;padding:0;background:none;}
}
</style>
  <script src="/HA-EE/src/javascript/systeme.js" type="module"></script>
</head>
<body perms.pages="2;shootingrange;page.certif_shootingrange">

<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar-left">
    <div class="topbar-logo">Howard Armory<span>Nashville, Tennessee</span></div>
    <div class="topbar-sep"></div>
    <div class="topbar-session">Session : <strong id="sess-name">Chargement…</strong> — <span id="sess-poste" style="color:var(--text-dim)"></span></div>
  </div>
  <div class="topbar-right">
    <div class="topbar-badge"><i class="fas fa-shield-halved" style="color:var(--gold);margin-right:6px;"></i>Panel Certifications</div>
  </div>
</div>

<!-- TABS -->
<nav class="tabs-nav">
  <button class="tab-btn active" onclick="switchTab('form',this)"><i class="fas fa-file-signature"></i>Émettre un Certificat</button>
  <button class="tab-btn" onclick="switchTab('list',this)"><i class="fas fa-list"></i>Registre</button>
  <button class="tab-btn" onclick="switchTab('search',this)"><i class="fas fa-search"></i>Recherche Client</button>
</nav>

<main class="main">

<!-- ══════════ TAB FORMULAIRE ══════════ -->
<div class="tab-panel active" id="tab-form">
  <div class="section-header">
    <div class="section-title">Émission d'un Certificat de Formation</div>
    <div class="section-sub">Document officiel — signé par l'instructeur en session</div>
  </div>

  <!-- Instructeur auto -->
  <div class="inst-banner" id="inst-banner">
    <div class="inst-avatar" id="inst-avatar">—</div>
    <div class="inst-info">
      <div class="inst-name" id="inst-full-name">Chargement de la session…</div>
      <div class="inst-meta" id="inst-meta-line"></div>
      <div class="inst-status">Instructeur actif — Signataire du présent document</div>
      <div class="inst-mode-toggle" id="inst-mode-toggle" style="margin-top:8px;display:flex;gap:8px;align-items:center;">
        <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:9px;letter-spacing:0.1em;">
          <input type="radio" name="inst-mode" value="auto" checked onchange="toggleInstMode(this.value)"> Auto
        </label>
        <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:9px;letter-spacing:0.1em;">
          <input type="radio" name="inst-mode" value="manuel" onchange="toggleInstMode(this.value)"> Manuel
        </label>
      </div>
      <select id="inst-select" onchange="selectManualInst(this.value)" style="margin-top:6px;padding:4px 6px;font-size:10px;border:1px solid var(--border);border-radius:3px;background:var(--bg);color:var(--text);display:none;width:100%;max-width:200px;">
        <option value="">— Choisir instructeur —</option>
      </select>
    </div>
    <div style="text-align:right;font-size:10px;color:var(--text-dim);line-height:1.8;">
      <div>ID Compte</div>
      <div style="color:var(--gold);font-size:14px;font-family:var(--display);" id="inst-id">—</div>
    </div>
  </div>

  <!-- Aperçu déclaration -->
  <div class="card">
    <div class="card-title"><i class="fas fa-scroll"></i>Aperçu de la Déclaration Officielle</div>
    <div class="decl-box" id="decl-preview">
      Je soussigné(e) <span class="fill" id="pv-inst">NOM Prénom</span>, né(e) le <span class="fill" id="pv-inst-dob">__/__/____</span>, exerçant la fonction de <span class="fill" id="pv-inst-poste">Poste</span> au sein de <em style="font-style:italic;color:var(--text);">Howard Armory, Nashville, Tennessee, U.S.A.</em>, atteste par le présent document avoir personnellement dispensé une formation de type <span class="fill" id="pv-type">—</span> à :<br><br>
      <span class="fill" id="pv-client">N. Prénom</span>, né(e) le <span class="fill" id="pv-client-dob">__/__/____</span>, de statut <span class="fill" id="pv-statut">—</span>.<br><br>
      Dans le cadre de cette formation intitulée <span class="fill" id="pv-form-nom">—</span>, dispensée le <span class="fill" id="pv-form-date">__/__/____</span>, le candidat a suivi les modules ci-après, dont l'état d'acquisition est établi de manière exhaustive et certifiée :<br>
      <span id="pv-cours-prat"></span>
      <span id="pv-cours-theo"></span>
    </div>
  </div>

  <!-- Candidat -->
  <div class="card">
    <div class="card-title"><i class="fas fa-user"></i>Identité du Candidat Formé</div>
    <div class="f-row">
      <div><label>Nom de famille *</label><input type="text" id="c-nom" placeholder="MARTIN" oninput="updatePreview()"></div>
      <div><label>Prénom *</label><input type="text" id="c-prenom" placeholder="Sophie" oninput="updatePreview()"></div>
    </div>
    <div class="f-row">
      <div><label>Date de naissance</label><input type="date" id="c-dob" oninput="updatePreview()"></div>
      <div>
        <label>Statut du candidat</label>
        <select id="c-statut" oninput="updatePreview()">
          <option value="CLIENT CIVIL">Client Civil</option>
          <option value="AGENT HOWARD ARMORY">Agent Howard Armory</option>
          <option value="PARTENAIRE EXTERNE">Partenaire Externe</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Formation -->
  <div class="card">
    <div class="card-title"><i class="fas fa-crosshairs"></i>Formation Dispensée</div>
    <div style="margin-bottom:1rem;font-size:10px;letter-spacing:0.1em;color:var(--text-dim);">Sélectionner le programme Howard Armory correspondant :</div>
    <div class="formation-grid" id="formation-grid">
      <!-- généré par JS -->
    </div>
    <div class="f-row" style="margin-top:1rem;">
      <div><label>Date de la formation *</label><input type="date" id="f-date" oninput="updatePreview()"></div>
      <div>
        <label>Type de séance</label>
        <select id="f-type" oninput="updatePreview()">
          <option value="pratique">Pratique uniquement</option>
          <option value="theorique">Théorique uniquement</option>
          <option value="mixte" selected>Mixte — Pratique & Théorique</option>
        </select>
      </div>
    </div>
    <div class="f-row full">
      <div><label>Précision / Variante (optionnel)</label><input type="text" id="f-precision" placeholder="ex : Session individuelle, munitions .45 ACP fournies…" oninput="updatePreview()"></div>
    </div>
  </div>

  <!-- Cours pratiques -->
  <div class="card">
    <div class="card-title"><i class="fas fa-bullseye"></i>Modules Pratiques</div>
    <div class="cours-header">Cours pratiques — vue & acquis</div>
    <div class="cours-list" id="list-prat"></div>
    <button class="btn-add" onclick="addCours('prat')">+ Ajouter un module pratique</button>
  </div>

  <!-- Cours théoriques -->
  <div class="card">
    <div class="card-title"><i class="fas fa-book-open"></i>Modules Théoriques</div>
    <div class="cours-header">Cours théoriques — vue & acquis</div>
    <div class="cours-list" id="list-theo"></div>
    <button class="btn-add" onclick="addCours('theo')">+ Ajouter un module théorique</button>
  </div>

  <!-- Observations -->
  <div class="card">
    <div class="card-title"><i class="fas fa-pen-nib"></i>Observations de l'Instructeur</div>
    <div class="f-row full">
      <div>
        <label>Remarques officielles — apparaîtront sur le certificat</label>
        <textarea id="f-obs" placeholder="Comportement exemplaire durant les exercices. Maîtrise démontrée du protocole de sécurité passive. Le candidat a fait preuve d'une rigueur…"></textarea>
      </div>
    </div>
  </div>

  <div class="btn-row">
    <button class="btn-primary" onclick="genCertif()"><i class="fas fa-certificate" style="margin-right:8px;"></i>Générer & Enregistrer</button>
    <button class="btn-secondary" onclick="resetForm()">Réinitialiser</button>
    <span style="font-size:10px;color:var(--text-muted);margin-left:auto;letter-spacing:0.1em;">
      <i class="fas fa-database" style="margin-right:5px;color:var(--text-muted);"></i>Le certificat HTML sera sauvegardé en base à la génération
    </span>
  </div>
</div>

<!-- ══════════ TAB REGISTRE ══════════ -->
<div class="tab-panel" id="tab-list">
  <div class="section-header">
    <div class="section-title">Registre des Certifications</div>
    <div class="section-sub">Howard Armory — Base de données interne</div>
  </div>
  <div class="stats-grid">
    <div class="stat-card"><div class="stat-num" id="s-total">0</div><div class="stat-lbl">Total</div></div>
    <div class="stat-card"><div class="stat-num" id="s-prat">0</div><div class="stat-lbl">Pratique</div></div>
    <div class="stat-card"><div class="stat-num" id="s-theo">0</div><div class="stat-lbl">Théorique</div></div>
    <div class="stat-card"><div class="stat-num" id="s-mixte">0</div><div class="stat-lbl">Mixte</div></div>
  </div>
  <div class="search-row">
    <input type="text" id="l-search" placeholder="Filtrer par nom, instructeur, formation, référence…" oninput="renderList()">
  </div>
  <div class="card" style="padding:0;overflow:hidden;">
    <table class="certif-table">
      <thead>
        <tr>
          <th>Référence</th><th>Candidat</th><th>Instructeur</th><th>Formation</th><th>Type</th><th>Date</th><th></th>
        </tr>
      </thead>
      <tbody id="certif-tbody">
        <tr><td colspan="7" style="text-align:center;color:var(--text-dim);padding:2.5rem;letter-spacing:0.1em;">AUCUN CERTIFICAT ENREGISTRÉ</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- ══════════ TAB RECHERCHE ══════════ -->
<div class="tab-panel" id="tab-search">
  <div class="section-header">
    <div class="section-title" id="search-title">Portail de Vérification Client</div>
    <div class="section-sub" id="search-sub">Recherche par identité — accès public</div>
  </div>
  <div class="card" style="margin-bottom:1rem;">
    <div class="f-row" style="align-items:center;gap:1rem;">
      <span style="font-size:10px;letter-spacing:0.1em;color:var(--text-dim);">MODE :</span>
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:9px;">
        <input type="radio" name="search-mode" value="client" checked onchange="toggleSearchMode(this.value)"> Client
      </label>
      <label style="display:flex;align-items:center;gap:4px;cursor:pointer;font-size:9px;">
        <input type="radio" name="search-mode" value="admin" onchange="toggleSearchMode(this.value)"> Admin
      </label>
    </div>
  </div>
  <div class="card">
    <div class="card-title"><i class="fas fa-id-card"></i>Identification du Candidat</div>
    <div class="f-row">
      <div><label>Nom de famille</label><input type="text" id="s-nom" placeholder="MARTIN"></div>
      <div><label>Prénom</label><input type="text" id="s-prenom" placeholder="Sophie"></div>
    </div>
    <div class="btn-row" style="margin-top:0.75rem;">
      <button class="btn-primary" onclick="doSearch()"><i class="fas fa-search" style="margin-right:8px;"></i>Rechercher</button>
    </div>
  </div>
  <div id="search-results"></div>
</div>

</main>

<!-- MODAL CERTIFICAT -->
<div class="modal-overlay" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-actions">
      <button class="btn-primary" onclick="window.print()"><i class="fas fa-print" style="margin-right:6px;"></i>Imprimer / PDF</button>
      <button class="btn-secondary" onclick="copyHTML()"><i class="fas fa-code" style="margin-right:6px;"></i>Copier HTML</button>
      <button class="modal-close" onclick="closeModal()">✕ Fermer</button>
    </div>
    <div id="modal-content"></div>
  </div>
</div>

<div class="notif" id="notif"></div>

<script type="module">
// ══ Import Supabase ══
import { supabase, fromAgence, insertAgence, withAgence } from '/HA-EE/src/javascript/sp.js';
window._sb = supabase;

// ══ Helpers pour hash email ══
async function hashEmail(email) {
  const utf8 = new TextEncoder().encode(email.toLowerCase().trim());
  const hashBuffer = await crypto.subtle.digest('SHA-256', utf8);
  const hashArray = Array.from(new Uint8Array(hashBuffer));
  return hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
}

// ══ Session Instructeur ══
let SESSION = null;

async function loadSession() {
  try {
    // 1. Vérifier Supabase auth direct
    const { data: { user } } = await supabase.auth.getUser();
    if (user) {
      const { data: emp } = await fromAgence('employes').select('*').eq('email', user.email).single();
      if (emp) {
        SESSION = emp;
        document.getElementById('sess-name').textContent = emp.nom + ' ' + emp.prenom;
        document.getElementById('sess-poste').textContent = emp.poste || 'Employé';
        setInstBanner(emp);
        updatePreview();
        return;
      }
    }
    // 2. Vérifier sessionStorage PKYT (système externe)
    if (sessionStorage.getItem('isAuth') === 'true' && sessionStorage.getItem('session_token')) {
      // Chercher dans employes par hash email
      // Note: on ne peut pas inverser le hash, donc on cherche par token stocké
      // Pour solution simple: utiliser le dernier employé connecté ou tous les employes actifs
      const { data: emps } = await fromAgence('employes').select('*').neq('statut', 'inactif').order('nom');
      if (emps?.length) {
        // Utiliser le premier employé actif comme fallback
        // Pour une meilleure solution, stocker l email en clair dans sessionStorage
        const emp = emps[0];
        SESSION = emp;
        document.getElementById('sess-name').textContent = emp.nom + ' ' + emp.prenom;
        document.getElementById('sess-poste').textContent = emp.poste || 'Employé';
        setInstBanner(emp);
        updatePreview();
        return;
      }
    }
    // Pas de session - basculement auto en mode manuel
    showNoSession();
  } catch(e) { showNoSession(); }
}

function showNoSession() {
  document.getElementById('sess-name').textContent = 'Non connecté';
  document.getElementById('inst-full-name').textContent = 'Aucune session active';
  document.getElementById('inst-meta-line').textContent = 'Connectez-vous pour émettre un certificat';
  document.querySelector('input[name="inst-mode"][value="manuel"]').checked = true;
  document.getElementById('inst-select').style.display = 'block';
}

function setInstBanner(emp) {
  if (!emp) return;
  document.getElementById('inst-full-name').innerHTML = `${emp.nom} <span>${emp.prenom}</span>`;
  document.getElementById('inst-meta-line').textContent = (emp.poste||'Non assigné') + '  ·  Échelon : ' + (emp.echelon||'?');
  document.getElementById('inst-id').textContent = '#' + emp.id_compte;
  const initials = (emp.nom[0]||'') + (emp.prenom[0]||'');
  document.getElementById('inst-avatar').textContent = initials;
}

let MANUAL_INSTS = [];
window.toggleInstMode = async function(mode) {
  const select = document.getElementById('inst-select');
  if (mode === 'manuel') {
    select.style.display = 'block';
    if (!MANUAL_INSTS.length) {
      const { data } = await _sb.from('employes').select('id_compte,nom,prenom,poste,echelon,date_naissance').order('nom');
      MANUAL_INSTS = data || [];
      select.innerHTML = '<option value="">— Choisir instructeur —</option>' + 
        MANUAL_INSTS.map(e => `<option value="${e.id_compte}" data-poste="${e.poste||''}" data-echelon="${e.echelon||''}" data-dob="${e.date_naissance||''}">${e.nom} ${e.prenom}</option>`).join('');
    }
  } else {
    select.style.display = 'none';
    select.value = '';
    if (SESSION) setInstBanner(SESSION);
  }
};

window.selectManualInst = async function(id) {
  if (!id) return;
  const emp = MANUAL_INSTS.find(e => e.id_compte == id);
  if (emp) {
    SESSION = { ...emp };
    setInstBanner(emp);
    updatePreview();
  }
};

// ══ Formations catalogue ══
const FORMATIONS = [
  { id:'initiation', nom:'Initiation au tir', desc:'Découverte & Sécurité', prix:'$150', type:'pratique' },
  { id:'base', nom:'Formation Base', desc:'Théorie & pratique', prix:'$250', type:'mixte' },
  { id:'poing', nom:'F. + Tir (Armes de poing)', desc:'Spécialisation 9mm / .45', prix:'$500', type:'mixte' },
  { id:'epaule', nom:'F. + Tir (Armes d\'épaule)', desc:'Fusils à pompe & Carabines', prix:'$750', type:'mixte' },
  { id:'precision', nom:'F. + Tir (Précision)', desc:'Tir longue distance', prix:'$900', type:'mixte' },
  { id:'toutes', nom:'F. + Tir (Toutes Armes)', desc:'Masterclass complète', prix:'$1 000', type:'mixte', popular:true },
  { id:'defense', nom:'Légitime Défense', desc:'Aspects légaux & ripostes', prix:'Soon', type:'mixte', soon:true },
  { id:'tactique', nom:'Tactique Avancée', desc:'CQB & Coordination', prix:'Soon', type:'mixte', soon:true },
];
let selectedFormation = null;

function renderFormations() {
  const grid = document.getElementById('formation-grid');
  grid.innerHTML = FORMATIONS.map(f => `
    <div class="formation-card${f.soon?' soon':''}" id="fc-${f.id}" onclick="${f.soon?'':` selectFormation('${f.id}')`}">
      ${f.popular ? '<div class="fc-popular">Most Popular</div>' : ''}
      <div class="fc-price">${f.prix}</div>
      <div class="fc-name">${f.nom}</div>
      <div class="fc-desc">${f.desc}</div>
      ${f.soon ? '<div class="fc-soon">Bientôt disponible</div>' : ''}
    </div>
  `).join('');
}
window.selectFormation = function(id) {
  selectedFormation = FORMATIONS.find(f => f.id === id);
  document.querySelectorAll('.formation-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('fc-' + id)?.classList.add('selected');
  if (selectedFormation) {
    document.getElementById('f-type').value = selectedFormation.type;
  }
  updatePreview();
};

// ══ Cours builder ══
function addCours(type) {
  const list = document.getElementById('list-' + type);
  const uid = type + '_' + Date.now();
  const div = document.createElement('div');
  div.className = 'cours-item';
  div.id = uid;
  div.innerHTML = `
    <input type="text" placeholder="Intitulé du module…" oninput="updatePreview()">
    <label class="chk-label vu"><input type="checkbox" onchange="updatePreview()"><span>Vu</span></label>
    <label class="chk-label acq"><input type="checkbox" onchange="updatePreview()"><span>Acquis</span></label>
    <button class="btn-del" onclick="document.getElementById('${uid}').remove();updatePreview()">✕</button>
  `;
  list.appendChild(div);
}
window.addCours = addCours;

function getCours(type) {
  return Array.from(document.getElementById('list-'+type).querySelectorAll('.cours-item')).map(el => ({
    nom: el.querySelector('input[type=text]').value.trim(),
    vu: el.querySelectorAll('input[type=checkbox]')[0].checked,
    acq: el.querySelectorAll('input[type=checkbox]')[1].checked,
  })).filter(c => c.nom);
}

// ══ Preview ══
function fmtD(v) {
  if (!v) return '__/__/____';
  const [y,m,d] = v.split('-');
  return `${d}/${m}/${y}`;
}
function typeLabel(v) {
  return {pratique:'Pratique',theorique:'Théorique',mixte:'Mixte — Pratique & Théorique'}[v]||'—';
}
window.updatePreview = function() {
  const inst = SESSION;
  const iName = inst ? `${inst.nom} ${inst.prenom}` : 'NOM Prénom';
  const iDob = inst?.date_naissance ? fmtD(inst.date_naissance) : '__/__/____';
  const iPoste = inst?.poste || 'Poste non défini';
  const cNom = (document.getElementById('c-nom').value||'N.').toUpperCase();
  const cPre = document.getElementById('c-prenom').value||'Prénom';
  const cDob = fmtD(document.getElementById('c-dob').value);
  const cStat = document.getElementById('c-statut').value;
  const fNom = selectedFormation?.nom || (document.getElementById('f-precision')?.value || '—');
  const fDate = fmtD(document.getElementById('f-date').value);
  const fType = typeLabel(document.getElementById('f-type').value);

  const setFill = (id, v) => { const el = document.getElementById(id); if(el) { el.textContent = v; el.className = v && v !== '—' && !v.includes('__') ? 'fill' : 'blank'; }};
  setFill('pv-inst', iName);
  setFill('pv-inst-dob', iDob);
  setFill('pv-inst-poste', iPoste);
  setFill('pv-type', fType);
  setFill('pv-client', cNom[0] + '. ' + cPre);
  setFill('pv-client-dob', cDob);
  setFill('pv-statut', cStat);
  setFill('pv-form-nom', fNom);
  setFill('pv-form-date', fDate);

  const pratCours = getCours('prat');
  const theoCours = getCours('theo');
  const pratHtml = pratCours.length ? '<ul style="margin:0.5rem 0 0.5rem 1.5rem;">' + pratCours.map(c=>`<li style="color:${c.acq?'var(--green2)':'var(--text-dim)'};">[PRATIQUE] ${c.nom} — <b>${c.acq?'ACQUIS':'VU'}</b></li>`).join('')+'</ul>' : '';
  const theoHtml = theoCours.length ? '<ul style="margin:0.5rem 0 0.5rem 1.5rem;">' + theoCours.map(c=>`<li style="color:${c.acq?'var(--green2)':'var(--text-dim)'};">[THÉORIQUE] ${c.nom} — <b>${c.acq?'ACQUIS':'VU'}</b></li>`).join('')+'</ul>' : '';
  document.getElementById('pv-cours-prat').innerHTML = pratHtml;
  document.getElementById('pv-cours-theo').innerHTML = theoHtml;
};

// ══ Générer certificat ══
window.genCertif = async function() {
  if (!SESSION) { showNotif('⚠ Aucune session active'); return; }
  const cNom = document.getElementById('c-nom').value.trim().toUpperCase();
  const cPre = document.getElementById('c-prenom').value.trim();
  const cDob = document.getElementById('c-dob').value;
  const cStat = document.getElementById('c-statut').value;
  const fDate = document.getElementById('f-date').value;
  const fType = document.getElementById('f-type').value;
  const fPrec = document.getElementById('f-precision').value.trim();
  const obs = document.getElementById('f-obs').value.trim();
  const pratCours = getCours('prat');
  const theoCours = getCours('theo');
  if (!cNom || !cPre || !fDate) { showNotif('⚠ Nom candidat et date obligatoires'); return; }
  if (!selectedFormation) { showNotif('⚠ Veuillez sélectionner une formation'); return; }

  const ref = 'HA-' + Date.now().toString(36).toUpperCase().slice(-6);
  const fNom = selectedFormation.nom + (fPrec ? ' — ' + fPrec : '');
  const htmlSnap = buildCertifHTML({ref, fNom, fDate, fType, obs, pratCours, theoCours, cNom, cPre, cDob, cStat});

  // Supabase insert
  const { data: certif, error } = await _sb.from('ha_certificats').insert({
    ref, instructeur_id: SESSION.id_compte,
    client_nom: cNom, client_prenom: cPre,
    client_dob: cDob || null, client_statut: cStat,
    formation_nom: fNom, formation_date: fDate,
    type_formation: fType, observations: obs || null,
    html_snapshot: htmlSnap,
  }).select().single();

  if (error) { showNotif('Erreur DB : ' + error.message); return; }

  // Cours
  const coursRows = [
    ...pratCours.map((c,i) => ({certificat_id:certif.id, type_cours:'pratique', intitule:c.nom, vu:c.vu, acquis:c.acq, ordre:i})),
    ...theoCours.map((c,i) => ({certificat_id:certif.id, type_cours:'theorique', intitule:c.nom, vu:c.vu, acquis:c.acq, ordre:i})),
  ];
  if (coursRows.length) await _sb.from('ha_certif_cours').insert(coursRows);

  showModal(htmlSnap);
  showNotif('✓ Certificat ' + ref + ' enregistré');
};

// ══ HTML Certificat National ══
function cornerSVG() {
  return `<svg viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M2 2 L2 20 M2 2 L20 2" stroke="#8B6914" stroke-width="2"/>
    <path d="M8 8 L8 16 M8 8 L16 8" stroke="#C9A84C" stroke-width="1"/>
    <circle cx="2" cy="2" r="2" fill="#8B6914"/>
    <circle cx="8" cy="8" r="1.5" fill="#C9A84C"/>
  </svg>`;
}

function buildCertifHTML(c) {
  const inst = SESSION;
  const instName = inst ? `${inst.nom} ${inst.prenom}` : '—';
  const instDob = inst?.date_naissance ? fmtD(inst.date_naissance) : 'Non renseignée';
  const instPoste = inst?.poste || 'Instructeur';
  const instEch = inst?.echelon ? ' — Échelon : ' + inst.echelon : '';
  const tLabel = typeLabel(c.fType);

  const coursBlock = (list, label, typeKey) => {
    if (!list.length) return '';
    return `
      <div class="certif-cours-section">
        <div class="certif-cours-label">◈ Modules ${label}</div>
        <ul class="certif-cours-list">
          ${list.map(cours => `
            <li class="${cours.acq?'acq':'vu'}">
              <span class="cc-status">${cours.acq?'ACQUIS':'VU'}</span>
              <span class="cc-name">${cours.nom}</span>
            </li>
          `).join('')}
        </ul>
      </div>`;
  };

  const obsBlock = c.obs ? `
    <div class="certif-obs">
      <div class="certif-obs-label">◈ Observations de l'Instructeur</div>
      <div class="certif-obs-text">« ${c.obs} »</div>
    </div>` : '';

  const now = new Date();
  const dateEmission = now.toLocaleDateString('fr-FR',{day:'2-digit',month:'long',year:'numeric'});

  return `
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;900&family=Crimson+Pro:ital,wght@0,300;0,400;0,600;1,300;1,400&family=IBM+Plex+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<div class="certif-wrap" style="background:#FDFAF3;color:#1A1208;position:relative;font-family:'Crimson Pro',serif;overflow:hidden;">

  <div style="position:absolute;inset:12px;border:2px solid #8B6914;pointer-events:none;z-index:1;"></div>
  <div style="position:absolute;inset:18px;border:1px solid rgba(139,105,20,0.35);pointer-events:none;z-index:1;"></div>

  <!-- Coins -->
  ${['top:8px;left:8px;','top:8px;right:8px;transform:scaleX(-1);','bottom:8px;left:8px;transform:scaleY(-1);','bottom:8px;right:8px;transform:scale(-1,-1);'].map(s=>`
    <div style="position:absolute;${s}width:52px;height:52px;z-index:2;">
      <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;">
        <path d="M2 2 L2 22 M2 2 L22 2" stroke="#8B6914" stroke-width="2.5"/>
        <path d="M9 9 L9 17 M9 9 L17 9" stroke="#C9A84C" stroke-width="1.2"/>
        <circle cx="2" cy="2" r="2.5" fill="#8B6914"/>
        <circle cx="9" cy="9" r="1.8" fill="#C9A84C"/>
      </svg>
    </div>`).join('')}

  <!-- Watermark -->
  <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) rotate(-30deg);font-family:'Cinzel',serif;font-size:85px;font-weight:900;letter-spacing:0.05em;color:rgba(139,105,20,0.04);white-space:nowrap;pointer-events:none;z-index:0;text-align:center;line-height:1.2;">HOWARD<br>ARMORY</div>

  <div style="position:relative;z-index:2;padding:56px 64px 44px;">

    <!-- HEADER -->
    <div style="text-align:center;margin-bottom:24px;">
      <div style="display:flex;align-items:center;justify-content:center;gap:28px;margin-bottom:14px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#C9A84C);"></div>
        <div style="width:78px;height:78px;border-radius:50%;border:3px double #8B6914;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(139,105,20,0.05);font-family:'Cinzel',serif;color:#6B5010;text-align:center;flex-shrink:0;">
          <span style="font-size:16px;font-weight:700;letter-spacing:0.08em;">H·A</span>
          <span style="font-size:7px;letter-spacing:0.15em;margin-top:1px;">EST. 2023</span>
        </div>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,#C9A84C,transparent);"></div>
      </div>
      <div style="font-family:'Cinzel',serif;font-size:34px;font-weight:700;letter-spacing:0.22em;color:#3A1F00;line-height:1;">HOWARD ARMORY</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.4em;color:#8B6914;text-transform:uppercase;margin-top:5px;">Nashville, Tennessee, U.S.A. — Since 2023</div>
      <div style="display:flex;align-items:center;gap:12px;margin:14px 0 10px;">
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);"></div>
        <div style="width:8px;height:8px;background:#8B6914;transform:rotate(45deg);flex-shrink:0;"></div>
        <div style="flex:1;height:1px;background:linear-gradient(90deg,transparent,#C9A84C,transparent);"></div>
      </div>
      <div style="font-family:'Cinzel',serif;font-size:19px;letter-spacing:0.35em;color:#2A1800;text-transform:uppercase;margin-bottom:4px;">Certificat de Formation</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.25em;color:#8B6914;text-transform:uppercase;">${tLabel}</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:#A08040;margin-top:7px;letter-spacing:0.08em;">Référence : <strong>${c.ref}</strong> &nbsp;·&nbsp; Émis le : ${dateEmission}</div>
    </div>

    <!-- CORPS -->
    <div style="font-family:'Crimson Pro',serif;font-size:15.5px;line-height:2.1;color:#1A1208;text-align:justify;margin:20px 0 16px;">
      <p>Je soussigné(e) <strong style="border-bottom:1px solid rgba(139,105,20,0.5);">${instName}</strong>, né(e) le <strong style="border-bottom:1px solid rgba(139,105,20,0.5);">${instDob}</strong>, exerçant la fonction de <em><strong>${instPoste}</strong>${instEch}</em> au sein de <em>Howard Armory, Nashville, Tennessee, U.S.A.</em>, atteste par le présent document avoir personnellement dispensé une formation officielle de type <strong>${tLabel}</strong> à :</p>
    </div>

    <!-- Encart candidat -->
    <div style="border:1px solid rgba(139,105,20,0.4);border-left:5px solid #8B6914;background:rgba(200,184,112,0.07);padding:14px 22px;margin:6px 0 16px;border-radius:0 2px 2px 0;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.3em;text-transform:uppercase;color:#8B6914;margin-bottom:5px;">◈ Identité du Candidat</div>
      <div style="font-family:'Cinzel',serif;font-size:20px;color:#1A3A22;letter-spacing:0.08em;">${c.cNom} ${c.cPre}</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:#A08040;margin-top:3px;">Né(e) le : ${fmtD(c.cDob)} &nbsp;·&nbsp; Statut : ${c.cStat}</div>
    </div>

    <div style="font-family:'Crimson Pro',serif;font-size:15.5px;line-height:2.1;color:#1A1208;text-align:justify;margin:8px 0 12px;">
      <p>Dans le cadre de cette formation, le candidat a suivi les modules ci-après, dont l'état d'acquisition a été évalué et certifié à l'issue de chaque séance :</p>
    </div>

    <!-- Encart formation -->
    <div style="border:1px solid rgba(139,105,20,0.3);border-left:4px solid #C9A84C;background:rgba(200,184,112,0.06);padding:12px 20px;margin:0 0 18px;border-radius:0 2px 2px 0;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.25em;text-transform:uppercase;color:#8B6914;margin-bottom:4px;">◈ Formation</div>
      <div style="font-family:'Crimson Pro',serif;font-size:18px;font-weight:600;color:#2A1800;font-style:italic;">${c.fNom}</div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:#A08040;margin-top:4px;">Dispensée le : ${fmtD(c.fDate)} &nbsp;·&nbsp; Type : ${tLabel}</div>
    </div>

    ${coursBlock(c.pratCours, 'Pratiques', 'pratique')}
    ${coursBlock(c.theoCours, 'Théoriques', 'theorique')}
    ${obsBlock}

    <!-- Séparateur -->
    <div style="text-align:center;margin:22px 0;color:#C9A84C;letter-spacing:0.6em;font-size:14px;">✦ &nbsp; ✦ &nbsp; ✦</div>

    <!-- Signatures -->
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:20px;margin-top:10px;padding-top:18px;border-top:1px solid rgba(139,105,20,0.3);">
      <div style="text-align:center;">
        <div style="border-top:1px solid #8B6914;margin:32px auto 8px;width:82%;"></div>
        <div style="font-family:'Cinzel',serif;font-size:11px;font-weight:600;color:#2A1800;letter-spacing:0.05em;">${instName}</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:0.12em;text-transform:uppercase;color:#8B6914;margin-top:3px;">${instPoste}</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#A08040;margin-top:2px;">Instructeur signataire</div>
      </div>
      <div style="text-align:center;">
        <div style="width:70px;height:70px;border-radius:50%;border:2px double #8B6914;margin:0 auto 8px;display:flex;align-items:center;justify-content:center;background:rgba(139,105,20,0.05);">
          <div style="font-family:'Cinzel',serif;font-size:8px;color:#6B5010;text-align:center;line-height:1.3;letter-spacing:0.05em;">HOWARD<br>ARMORY<br><span style="font-size:7px;">NASHVILLE</span></div>
        </div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#A08040;letter-spacing:0.1em;">Cachet officiel</div>
      </div>
      <div style="text-align:center;">
        <div style="border-top:1px solid #8B6914;margin:32px auto 8px;width:82%;"></div>
        <div style="font-family:'Cinzel',serif;font-size:11px;font-weight:600;color:#2A1800;letter-spacing:0.05em;">Direction Générale</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;letter-spacing:0.12em;text-transform:uppercase;color:#8B6914;margin-top:3px;">Howard Armory</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#A08040;margin-top:2px;">Nashville, Tennessee</div>
      </div>
    </div>

    <!-- Footer légal -->
    <div style="margin-top:22px;padding-top:14px;border-top:1px solid rgba(139,105,20,0.2);display:flex;justify-content:space-between;align-items:flex-end;gap:16px;">
      <div style="font-size:11px;color:#8B7040;line-height:1.8;font-style:italic;max-width:380px;">
        <strong style="font-style:normal;font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.1em;color:#6B5010;display:block;margin-bottom:4px;">* Note légale</strong>
        Ce certificat est émis par <em>Howard Armory</em>, armurerie agréée dont le siège est établi à Nashville, Tennessee, U.S.A., ayant pour objet de prouver l'acquisition des compétences et de la posture nécessaires à la manipulation sécurisée des armes à feu. Ce document ne constitue pas un permis de port d'armes.
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#A08040;letter-spacing:0.08em;margin-bottom:4px;">howardarmory.vercel.app</div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:8px;color:#C0A040;letter-spacing:0.05em;">Howard Armory © Since 2023</div>
      </div>
    </div>

  </div>
</div>`;
}

// ══ Modal ══
function showModal(html) {
  document.getElementById('modal-content').innerHTML = html;
  document.getElementById('modal').classList.add('open');
}
window.closeModal = () => document.getElementById('modal').classList.remove('open');
window.copyHTML = () => {
  navigator.clipboard.writeText(document.getElementById('modal-content').innerHTML)
    .then(() => showNotif('HTML copié'));
};

// ══ Registre ══
window.renderList = async function() {
  const q = (document.getElementById('l-search')?.value||'').toLowerCase();
  const { data: rows } = await _sb.from('ha_registre').select('*').order('created_at', {ascending:false});
  if (!rows) return;
  const filtered = rows.filter(r => [r.ref,r.client_nom,r.client_prenom,r.inst_nom,r.inst_prenom,r.formation_nom].join(' ').toLowerCase().includes(q));

  document.getElementById('s-total').textContent = rows.length;
  document.getElementById('s-prat').textContent = rows.filter(r=>r.type_formation==='pratique').length;
  document.getElementById('s-theo').textContent = rows.filter(r=>r.type_formation==='theorique').length;
  document.getElementById('s-mixte').textContent = rows.filter(r=>r.type_formation==='mixte').length;

  const tbody = document.getElementById('certif-tbody');
  if (!filtered.length) {
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:var(--text-dim);padding:2.5rem;letter-spacing:0.1em;">AUCUN RÉSULTAT</td></tr>';
    return;
  }
  const pill = t => ({pratique:'pratique',theorique:'theorique',mixte:'mixte'}[t]||'');
  const pl = t => ({pratique:'Pratique',theorique:'Théorique',mixte:'Mixte'}[t]||'?');
  tbody.innerHTML = filtered.map(r => `
    <tr>
      <td class="t-ref">${r.ref}</td>
      <td><div class="t-name">${r.client_nom} ${r.client_prenom}</div></td>
      <td style="font-size:12px;">${r.inst_nom} ${r.inst_prenom}</td>
      <td style="font-size:11px;color:var(--text-dim);max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${r.formation_nom||'—'}</td>
      <td><span class="type-pill ${pill(r.type_formation)}">${pl(r.type_formation)}</span></td>
      <td class="t-date">${fmtD(r.formation_date)}</td>
      <td><button class="btn-view" onclick="viewRef('${r.ref}')">Voir ›</button></td>
    </tr>
  `).join('');
};

window.viewRef = async function(ref) {
  const { data } = await _sb.from('ha_certificats').select('html_snapshot').eq('ref', ref).single();
  if (data?.html_snapshot) showModal(data.html_snapshot);
};

window.toggleSearchMode = function(mode) {
  const title = document.getElementById('search-title');
  const sub = document.getElementById('search-sub');
  const nomI = document.getElementById('s-nom');
  const preI = document.getElementById('s-prenom');
  if (mode === 'admin') {
    title.textContent = 'Vérification Instructeur';
    sub.textContent = 'Recherche par identité — accès restreint';
    nomI.placeholder = 'Nom instructeur…';
    preI.placeholder = 'Prénom instructeur…';
  } else {
    title.textContent = 'Portail de Vérification Client';
    sub.textContent = 'Recherche par identité — accès public';
    nomI.placeholder = 'MARTIN';
    preI.placeholder = 'Sophie';
  }
};

let SEARCH_MODE = 'client';
window.doSearch = async function() {
  const mode = document.querySelector('input[name="search-mode"]:checked').value;
  const nom = document.getElementById('s-nom').value.trim().toUpperCase();
  const pre = document.getElementById('s-prenom').value.trim();
  const cont = document.getElementById('search-results');
  
  if (mode === 'admin') {
    const { data } = await _sb.from('ha_registre').select('*').ilike('inst_nom','%'+nom+'%').ilike('inst_prenom','%'+pre+'%').order('formation_date',{ascending:false});
    if (!data?.length) {
      cont.innerHTML = `<div class="card" style="text-align:center;color:var(--text-dim);padding:2rem;letter-spacing:0.1em;">AUCUN CERTIFICAT TROUVÉ POUR CET INSTRUCTEUR</div>`;
      return;
    }
    cont.innerHTML = `<div style="font-size:9px;letter-spacing:0.25em;color:var(--gold);text-transform:uppercase;margin-bottom:1rem;">${data.length} certification(s) trouvée(s) — Instructeur</div>` +
    data.map(r => `
      <div class="card" style="cursor:pointer;transition:border-color 0.2s;margin-bottom:1rem;" onclick="viewRef('${r.ref}')" onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='var(--border)'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
          <div>
            <div style="font-family:var(--serif);font-size:17px;margin-bottom:2px;">${r.client_nom} ${r.client_prenom}</div>
            <div style="font-size:9px;letter-spacing:0.15em;color:var(--text-dim);">${r.ref} — Formé le ${fmtD(r.formation_date)}</div>
          </div>
          <span class="type-pill ${r.type_formation}" style="margin-top:3px;">${{pratique:'Pratique',theorique:'Théorique',mixte:'Mixte'}[r.type_formation]||'?'}</span>
        </div>
        <div style="font-size:12px;color:var(--text-dim);">
          <i class="fas fa-graduation-cap" style="margin-right:4px;"></i>${r.formation_nom||'—'}
        </div>
        <div style="font-size:10px;color:var(--gold);text-align:right;margin-top:8px;">Cliquer pour voir le certificat ›</div>
      </div>
    `).join('');
  } else {
    const { data } = await _sb.from('ha_registre').select('*').ilike('client_nom','%'+nom+'%').ilike('client_prenom','%'+pre+'%').order('formation_date',{ascending:false});
    if (!data?.length) {
      cont.innerHTML = `<div class="card" style="text-align:center;color:var(--text-dim);padding:2rem;letter-spacing:0.1em;">AUCUN CERTIFICAT TROUVÉ POUR CET INDIVIDU</div>`;
      return;
    }
    cont.innerHTML = `<div style="font-size:9px;letter-spacing:0.25em;color:var(--text-dim);text-transform:uppercase;margin-bottom:1rem;">${data.length} certification(s) trouvée(s)</div>` +
    data.map(r => `
      <div class="card" style="cursor:pointer;transition:border-color 0.2s;margin-bottom:1rem;" onclick="viewRef('${r.ref}')" onmouseover="this.style.borderColor='var(--gold)'" onmouseout="this.style.borderColor='var(--border)'">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
          <div>
            <div style="font-family:var(--serif);font-size:17px;margin-bottom:2px;">${r.client_nom} ${r.client_prenom}</div>
            <div style="font-size:9px;letter-spacing:0.15em;color:var(--text-dim);">${r.ref} — Formé le ${fmtD(r.formation_date)}</div>
          </div>
          <span class="type-pill ${r.type_formation}" style="margin-top:3px;">${{pratique:'Pratique',theorique:'Théorique',mixte:'Mixte'}[r.type_formation]||'?'}</span>
        </div>
        <div style="font-size:12px;color:var(--text-dim);">
          <i class="fas fa-user-tie" style="color:var(--gold);margin-right:6px;"></i>Instructeur : ${r.inst_nom} ${r.inst_prenom} — ${r.inst_poste||''}
          &nbsp;·&nbsp;
          <i class="fas fa-graduation-cap" style="margin-right:4px;"></i>${r.formation_nom||'—'}
        </div>
        <div style="font-size:10px;color:var(--gold);text-align:right;margin-top:8px;">Cliquer pour voir le certificat ›</div>
      </div>
    `).join('');
  }
};

// ══ Tabs ══
window.switchTab = function(t, btn) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + t).classList.add('active');
  btn.classList.add('active');
  if (t === 'list') renderList();
};

window.resetForm = function() {
  ['c-nom','c-prenom','c-dob','f-date','f-precision','f-obs'].forEach(id => { const el = document.getElementById(id); if(el) el.value=''; });
  document.getElementById('f-type').value = 'mixte';
  selectedFormation = null;
  document.querySelectorAll('.formation-card').forEach(c => c.classList.remove('selected'));
  document.getElementById('list-prat').innerHTML = '';
  document.getElementById('list-theo').innerHTML = '';
  updatePreview();
};

function showNotif(msg) {
  const n = document.getElementById('notif');
  n.textContent = msg; n.style.display = 'block';
  setTimeout(() => n.style.display='none', 3500);
}

// ══ INIT ══
renderFormations();
loadSession();
</script>
</body>
</html>
